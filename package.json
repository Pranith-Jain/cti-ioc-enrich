{
  "name": "cti-ioc-enrich",
  "version": "0.1.0",
  "description": "Pluggable IOC enrichment framework. Compose your own provider adapters, get bounded concurrency + composite verdicts + per-provider provenance for free.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run test"
  },
  "keywords": [
    "cti",
    "ioc",
    "threat-intelligence",
    "enrichment",
    "virustotal",
    "abuseipdb",
    "shodan",
    "urlhaus",
    "threatfox"
  ],
  "author": "Pranith Jain",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pranith-Jain/cti-ioc-enrich.git"
  },
  "bugs": {
    "url": "https://github.com/Pranith-Jain/cti-ioc-enrich/issues"
  },
  "homepage": "https://github.com/Pranith-Jain/cti-ioc-enrich#readme",
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
